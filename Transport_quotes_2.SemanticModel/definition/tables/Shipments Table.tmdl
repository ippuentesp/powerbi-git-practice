		mode: import
		source =
				let
				    Origen = Excel.Workbook(File.Contents("C:\Users\USUARIO\Desktop\Evalueserve\Transport Quotes\Quotes Data.xlsx"), null, true),
				    Shipments_Sheet = Origen{[Item="Shipments",Kind="Sheet"]}[Data],
				    #"Encabezados promovidos" = Table.PromoteHeaders(Shipments_Sheet, [PromoteAllScalars=true]),
				    #"Tipo cambiado" = Table.TransformColumnTypes(#"Encabezados promovidos",{{"Shipment ID", type text}, {"Shipment Weight", Int64.Type}, {"Shipment Date", type date}, {"Destination Date", type date}, {"Asset Type", type text}, {"ROUTE DESCRIPTION", type text}, {"Fuel Cost", type number}, {"Millage", type number}, {"Shipment Revenue", Int64.Type}})
				in
				    #"Tipo cambiado"

	annotation PBI_NavigationStepName = Navigation

