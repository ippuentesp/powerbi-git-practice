	column QUOTE_PRICE = LOOKUPVALUE('Quotes Table'[QUOTE_PRICE],'Quotes Table'[SHIPMENT_ID],'Shipments Table'[Shipment ID])
		formatString: 0
		lineageTag: 114c254a-12fb-4dec-bf06-18ac4c058305
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column MAX_PRICE = LOOKUPVALUE('Quotes Table'[PRICE_GUIDE],'Quotes Table'[SHIPMENT_ID],'Shipments Table'[Shipment ID])
		lineageTag: 1751b4b0-e450-4ab1-8511-8a4b6c483b59
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column MIN_PRICE = LOOKUPVALUE('Quotes Table'[MINIMUM_SELING_PRICE],'Quotes Table'[SHIPMENT_ID],'Shipments Table'[Shipment ID])
		lineageTag: b9bbc2f5-3b31-4dd3-99db-d7516ea00a6e
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column PIECES = LOOKUPVALUE('Quotes Table'[PIECES],'Quotes Table'[SHIPMENT_ID],'Shipments Table'[Shipment ID])
		formatString: 0
		lineageTag: 4a3c4bd7-66bd-422c-b9b5-c46c5e70a20b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Ship Revenue' =
			
			var revenue = 'Shipments Table'[QUOTE_PRICE]*'Shipments Table'[PIECES]
			var newrevenue = 'Shipments Table'[PIECES]*IFERROR(((RANDBETWEEN(0,10)+month('Shipments Table'[Shipment Date])*30)*(('Shipments Table'[MAX_PRICE]-'Shipments Table'[MIN_PRICE])/100))+'Shipments Table'[MIN_PRICE],'Shipments Table'[QUOTE_PRICE])
			return
			if(revenue='Shipments Table'[Shipment Revenue],revenue,newrevenue)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: f2139a15-44a8-4847-b14f-5e0224360c2b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Fuel Cost OK' =
			
			VAR A = IF('Shipments Table'[Fuel Cost]>30000,'Shipments Table'[Fuel Cost]/100,'Shipments Table'[Fuel Cost])
			VAR B = IF('Shipments Table'[Fuel Cost]>30000,'Shipments Table'[Fuel Cost]/1000,'Shipments Table'[Fuel Cost])
			RETURN
			IF(A>'Shipments Table'[Ship Revenue],B,A)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: bc8eb70d-4773-442f-acb5-6bb808d5aaa2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column VALIDACION = 'Shipments Table'[Ship Revenue]-'Shipments Table'[Fuel Cost OK]
		lineageTag: c2b45b19-235c-4ac6-ae0a-3c22465be03f
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

